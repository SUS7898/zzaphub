# ==========================================
# 1. Java 기본 설정 (기존 디폴트 내용)
# ==========================================
# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# ==========================================
# 2. Eclipse 및 Spring Boot 설정 (추가할 내용)
# ==========================================
# Eclipse 관련 설정 파일 제외
.metadata
bin/
tmp/
*.tmp
*.bak
*.swp
*~.nib
local.properties
.settings/
.loadpath
.recommenders

# Eclipse 프로젝트 파일 제외 (팀원과 IDE 환경이 다를 수 있으므로 보통 제외)
.classpath
.project

# Spring Boot 빌드 폴더 제외
target/
build/
.gradle/

# 환경변수, DB 비밀번호 등이 담긴 파일 (보안)
application-secret.properties
application-secret.yml
##